function ModuleService:Bypass()
	local Success, Error = pcall(function()
		local Security = debug.getupvalue(CoreNet.send, 2)
		local Method = debug.getinfo(Security).what == "Lua"

		if not Method then error("Bypass Failed.") return end
		self[1].Hookfunction(
			Security,
			function(f, ...)
				return f(...)
			end
		)
	end)

	if not Success then error(Error) return end
	
	local Core = {
		Send = self[1].Clonefunction(CoreNet.send),
		Get = self[1].Clonefunction(CoreNet.get),
	}
	
	self[2].Send = function (...)
		local FirstArg = select(1, ...)
		if type(FirstArg) ~= "string" then
			warn("First argument is not a string. Network call blocked.")
			return
		end

		return Core.Send(...)
	end

	self[2].Get = function (...)
		local FirstArg = select(1, ...)
		if type(FirstArg) ~= "string" then
			warn("First argument is not a string. Network call blocked.")
			return
		end

		return Core.Get(...)
	end
end

function ModuleService:Closest(Instances, Condition, Target)
	local Condition = Condition or function() return true end
	local ClosestTarget = nil
	local ShortestDistance = math.huge
	
	
	for i, v in pairs(Instances:GetChildren()) do
		if Condition(v) then
			local Distance = (Target and Target or Root.Position - v.Position).Magnitude
			if Distance < ShortestDistance then
				ClosestTarget = v
				ShortestDistance = Distance
			end
		end
	end
	
	return ClosestTarget
end

function ModuleService:Detected()
	local Notification = Client.PlayerGui:FindFirstChild('Notifications')
	for _, v in pairs(Notification.Frame:GetChildren()) do
		if v.Name == "Notification" and (v.Text == "Teleport detected") then
			return true
		end
	end
	return nil
end

function ModuleService:Dist(Target)
	return (Root.Position - Target).Magnitude
end

local IsTeleporting = false
function ModuleService:Teleport(Destination)
	if IsTeleporting then return end
	IsTeleporting = true
	local Path = PathfindingService:CreatePath({
		AgentCanJump = true,
		AgentHeight = 3.8,
		AgentRadius = 2,
		AgentMaxSlope = 90,
		WaypointSpacing = 3,
		AgentJumpRadius = 50,
		AgentJumpHeight = 60,
		AgentCanClimb = true,
		AgentClimbHeight = 60,
		Costs = {
			DoorArea = 0;
			BlockedNode = 50;
		}
	})

	local Success, ErrorMessage = pcall(function()
		Path:ComputeAsync(Root.Position, Destination.CFrame)
	end)

	if not Success or Path.Status ~= Enum.PathStatus.Success then
		return
	end

	local Waypoints = Path:GetWaypoints()
	local BaseSpeed = 37

	for _, Waypoint in ipairs(Waypoints) do
		local OffsetY = (Waypoint.Action == Enum.PathWaypointAction.Jump) and 11 or 2.515
		local TargetPosition = Waypoint.Position + Vector3.new(0, OffsetY, 0)

		local StartPosition = Root.Position
		local DirectionVector = TargetPosition - StartPosition
		local Distance = DirectionVector.Magnitude

		if Distance < 0.1 then
			continue
		end

		local Direction = DirectionVector.Unit
		local StartTime = tick()
		local MovedDistance = 0

		while MovedDistance < Distance do
			if self:Detected() then
				continue
			end

			if Humanoid.Health <= 0 then
				continue
			end

			local ElapsedTime = tick() - StartTime
			MovedDistance = math.min(ElapsedTime * BaseSpeed, Distance)

			local NewPosition = StartPosition + Direction * MovedDistance

			if Humanoid.Sit then
				Humanoid.Sit = false
			end

			self[2].Send("set_sprinting_1", true)
			Root:PivotTo(CFrame.new(NewPosition))
			task.wait()
		end
	end

	IsTeleporting = false
	return true
end

function ModuleService:Get_Skill_Level(ClassName)
	local SkillsScrollingFrame = Client.PlayerGui.Skills.SkillsHolder.SkillsScrollingFrame
	for _, Child in pairs(SkillsScrollingFrame:GetChildren()) do
		if not Child:IsA("ImageButton") then continue end
		local Title = Child:FindFirstChild("SkillTitle")
		if Title then
			local Name, Level = string.match(Title.Text, "%s*([^:]-)%s*:%s*(%d+)")
			if Name and string.lower(Name) == string.lower(ClassName) then
				return tonumber(Level) or 0
			end
		end
	end
	return 0
end

function ModuleService:BurgePlace()
	local BurgePlaceBeacon = workspace:FindFirstChild("BurgePlaceBeacon")
	
	if Client:GetAttribute("Job") ~= "janitor" then
		if self:Dist(BurgePlaceBeacon:GetPivot().Position) > 10 then
			self:Teleport({ 
				CFrame = BurgePlaceBeacon:GetPivot().Position 
			})
			return
		end
		self[2].Send("apply_for_job", BurgePlaceBeacon)
		return
	end
	
	local ATM = self:Closest(workspace.Map.Props.ATMs, nil, BurgePlaceBeacon:GetPivot().Position)
	
	if CoreData.money.hand >= 100 and not self:Error(ATM) then
		local Position = ATM:GetPivot().Position
		self:Teleport({
			CFrame = Position
		})
		self[2].Get("transfer_funds", "hand", "bank", CoreData.money.hand)
		return
	end
	
	local Item = Client.Backpack:FindFirstChild("Mop") or Char:FindFirstChild("Mop")
	if Item.Parent == Client.Backpack then
		Item.Parent = Char
	end
	
	local Level = self:Get_Skill_Level("Janitor")
	local Interior = workspace.Map.Tiles.BurgerPlaceTile.BurgerPlace:FindFirstChild("Interior")
	local Puddle = self:Closest(Interior:FindFirstChild("Puddles"), function(v)
		return v.Transparency ~= 1 and 
			((v.Name == "LargePuddle" or v.Name == "SmallPuddle") and Level >= 5) or 
			(v.Name == "OilPuddle") and Level >= 35 or
			(v.Name == "ToxicPuddle" and Level >= 50) or 
			(v.Name == "NastyPuddle" and Level >= 35)
	end)
	
	if not Puddle then return end
	repeat
		if Client.Backpack:FindFirstChild("Mop") then
			Client.Backpack:FindFirstChild("Mop").Parent = Char
		end
		
		if Puddle.Transparency >= 0.99 then
			break
		end
		
		local PuddlePosition = Puddle:GetPivot().Position
		self:Teleport({ 
			CFrame = PuddlePosition 
		})
		
		self[2].Send("start_cleaning_puddle", Puddle)
		Puddle:GetPropertyChangedSignal("Transparency"):Wait()
	until Puddle.Transparency >= 0.99 or Humanoid.Health <= 0
end

function ModuleService:Quick_11()
	local TypeBox
	local Quick11 = workspace.Map.Tiles.GasStationTile:FindFirstChild("Quick11").Interior
	local Quick11_ATM = Quick11:FindFirstChild("ATM")
	local Quick11Beacon = Quick11:FindFirstChild("Quick11Beacon")
	local Quick11_Door = Quick11.DoorSystem
	
	if Client:GetAttribute("Job") ~= "shelf_stocker" then
		if self:Dist(Quick11_Door:GetPivot().Position) < 150 then
			self[2].Send("apply_for_job", Quick11Beacon)
		end
		self:Teleport({ 
			CFrame = Quick11_Door:GetPivot().Position 
		})
		return
	end
	
	if CoreData.money.hand >= 100 and not self:Error(Quick11_ATM) then
		local Position = Vector3.new(103, 255, 168)
		self:Teleport({
			CFrame = Position
		})
		self[2].Get("transfer_funds", "hand", "bank", CoreData.money.hand)
		return
	end

	local ShelfStock = Quick11.ShelfStockingJob
	local L_Box = ShelfStock:FindFirstChild("GoldenBox")
	local L_Box_Text = L_Box.BillboardGui.Frame.StockLeft.Text

	if tonumber(L_Box_Text:match("(%d+)/")) > 0 then
		TypeBox = "GoldenBox"
	else
		TypeBox = "NormalBox"
	end

	local CanNoclip = Vector3.new(98.5302963256836, 257.29205322265625, 205.9313201904297)
	local BoxTool = Client.Backpack:FindFirstChild("BoxTool") or Char:FindFirstChild("BoxTool")
	if not BoxTool then	
		if TypeBox == "GoldenBox" then
			local GoldenBoxPart = ShelfStock:FindFirstChild(TypeBox)
			local BoxPosition = GoldenBoxPart.Position

			self:Teleport({ 
				CFrame = CanNoclip
			})
			Root.CFrame = CFrame.new(CanNoclip)
			task.wait(.5)
			Root.CFrame = CFrame.new(CanNoclip - Vector3.yAxis * 20)
			task.wait(.5)

			self:Teleport({ 
				CFrame = BoxPosition
			})
			for i = 1, 10 do
				if GoldenBoxPart:FindFirstChild("ProximityPrompt") then
					self[1].FireProximityPrompt(GoldenBoxPart.ProximityPrompt)
				end
			end

			self:Teleport({ 
				CFrame = CanNoclip - Vector3.yAxis * 20
			})

			Root.CFrame = CFrame.new(CanNoclip - Vector3.yAxis * 20)
			task.wait(.5)
			Root.CFrame = CFrame.new(CanNoclip)
			task.wait(.5)
			return
		end

		if self:Dist(Quick11_Door:GetPivot().Position) > 20 then
			self:Teleport({ 
				CFrame = Quick11_Door:GetPivot().Position  
			})
			return
		end
		
		for i = 1, 8 do
			self[1].FireProximityPrompt(ShelfStock:FindFirstChild(TypeBox).ProximityPrompt)
		end
		return
	end

	local StandAttachment
	local StartCash = CoreData.money.hand
	for _, v in pairs(ShelfStock.Shelves:GetChildren()) do
		if v:FindFirstChild("Attachment") then
			StandAttachment = v.Position
			break
		end
	end
	
	if not StandAttachment then return end
	repeat
		if not BoxTool then break end
		if not Char:FindFirstChild("BoxTool") then
			Humanoid:EquipTool(BoxTool)
		end 
		if (Root.Position - StandAttachment).Magnitude > 2 then
			self:Teleport({
				CFrame = StandAttachment
			})
		end
		RunService.Heartbeat:Wait()
	until CoreData.money.hand > StartCash or Humanoid.Health <= 0 or not BoxTool
end

