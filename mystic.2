local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local PathfindingService = game:GetService("PathfindingService")
local CollectionService = game:GetService("CollectionService")

do
	Writefile = writefile
	Readfile = readfile
	Isfile = isfile
	Isfolder = isfolder
	Makefolder = makefolder
	Delfile = delfile
end

do
	FileName = tostring(Client.UserId).."_Settings.json"
	BaseFolder = "Mystic Hub"
	SubFolder = "Blox Spin"
end

local Config = {}

function SaveSetting() 
	local json = HttpService:JSONEncode(Config)

	if not Isfolder(BaseFolder) then
		Makefolder(BaseFolder)
	end
	if not Isfolder(BaseFolder.."/"..SubFolder) then
		Makefolder(BaseFolder.."/"..SubFolder)
	end

	Writefile(BaseFolder.."/"..SubFolder.."/"..FileName, json)
end

function LoadSetting()
	if Isfile(BaseFolder.."/"..SubFolder.."/"..FileName) then
		Config = HttpService:JSONDecode(Readfile(BaseFolder.."/"..SubFolder.."/"..FileName))
	end
end

LoadSetting()

